<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="controller.HelloController"
          hgap="10" vgap="10" style="-fx-padding:16">
    <columnConstraints>
        <ColumnConstraints percentWidth="30"/>
        <ColumnConstraints percentWidth="70"/>
    </columnConstraints>

    <Label text="Username" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="tfUsername" promptText="3–12 letters/digits"
               GridPane.rowIndex="0" GridPane.columnIndex="1"/>
    <Label fx:id="errUsername" textFill="red" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Email" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <TextField fx:id="tfEmail" promptText="name@example.com"
               GridPane.rowIndex="2" GridPane.columnIndex="1"/>
    <Label fx:id="errEmail" textFill="red" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Label text="Password" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
    <PasswordField fx:id="pfPassword" promptText="min 8, letter & digit"
                   GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    <Label fx:id="errPassword" textFill="red" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

    <Label text="Confirm" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
    <PasswordField fx:id="pfConfirm" promptText="must match"
                   GridPane.rowIndex="6" GridPane.columnIndex="1"/>
    <Label fx:id="errConfirm" textFill="red" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

    <CheckBox fx:id="cbAgree" text="I agree to the terms"
              GridPane.rowIndex="8" GridPane.columnIndex="1"/>

    <HBox spacing="10" GridPane.rowIndex="9" GridPane.columnIndex="1">
        <Button fx:id="btnCreate" text="Create" onAction="#onCreate"/>
        <Button text="Reset" onAction="#onReset"/>
    </HBox>
</GridPane>
